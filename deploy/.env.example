# ── Sao chép file này thành .env và điền giá trị thực ──────────────────────
# cp .env.example .env

# Domain của bạn (phải trỏ A record về IP VPS trước)
DOMAIN=waterfall.yourdomain.com

# Email để Let's Encrypt gửi thông báo hết hạn SSL
SSL_EMAIL=admin@yourdomain.com

# MQTT broker credentials
MQTT_USER=waterfall
MQTT_PASSWORD=change_this_password_123

# Flask secret key (tạo ngẫu nhiên: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET=change_this_secret_key

# Port backend nội bộ (không expose ra ngoài, Nginx sẽ proxy)
BACKEND_PORT=5000

# Môi trường
FLASK_ENV=production
